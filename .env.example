DATABASE_URL=postgresql+psycopg://dw:dw@localhost:5432/dw
DW_MAX_ARTIFACT_BYTES=10485760

# Off-box backup (production VPS only). Both must be set for dw-backup.sh
# to ship dumps to a remote machine. Example: a dedicated backup VPS over
# Tailscale.
# OFFBOX_RSYNC_TARGET=root@100.97.248.77:/var/dw-backups/
# OFFBOX_RSYNC_KEY=/root/.ssh/dw_backup_to_vps2
